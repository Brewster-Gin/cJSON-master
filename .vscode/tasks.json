{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "编译 test_pretty",
            "command": "gcc",
            "args": [
                "-o",
                "test_pretty.exe",
                "test_pretty.c",
                "cJSON.c",
                "-I.",
                "-lm"
            ],
            "options": {
                "cwd": "${workspaceFolder}/cJSON-master"  // 指定内层目录
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "shell",
            "label": "运行 test_pretty",
            "command": "test_pretty.exe",
            "options": {
                "cwd": "${workspaceFolder}/cJSON-master"  // 指定内层目录
            },
            "dependsOn": ["编译 test_pretty"],
            "problemMatcher": []
        }
    ]
}